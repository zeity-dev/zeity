{
  "name": "zeity-monorepo",
  "private": true,
  "version": "1.0.0-beta.5",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "pnpm run --parallel -r dev",
    "start:zeity": "pnpm --filter ./apps/zeity run dev",
    "start:docs": "pnpm run --filter zeity-docs dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "test": "vitest",
    "generate:migration": "pnpm --filter ./libs/database run generate:migration"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "nanoid": "^5.1.9"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.3.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint-plugin-regexp": "^3.1.0",
    "knip": "^5.88.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@netlify/functions": "-",
      "@netlify/blobs": "-"
    }
  },
  "resolutions": {
    "zod": "^4.3.6",
    "vite": "npm:rolldown-vite@latest"
  },
  "packageManager": "pnpm@10.33.0"
}
